generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model House {
  id             String   @id @default(cuid())
  name           String
  pricePerSet    Int      @default(120)
  defaultMaxRisk Int?
  defaultMaxSets Int?
  ratesJson      String
  createdAt      DateTime @default(now())
  users          User[]
  draws          Draw[]
  numberLimits   NumberLimit[]
}

model User {
  id           String   @id @default(cuid())
  houseId      String
  house        House    @relation(fields: [houseId], references: [id], onDelete: Cascade)
  username     String
  passwordHash String
  displayName  String
  role         String   @default("staff")
  createdAt    DateTime @default(now())
  bets         Bet[]

  @@unique([houseId, username])
}

model Draw {
  id            String    @id @default(cuid())
  houseId       String
  house         House     @relation(fields: [houseId], references: [id], onDelete: Cascade)
  label         String
  status        String    @default("open")
  result4       String?
  settledAt     DateTime?
  totalReceived Float?
  totalPayout   Float?
  createdAt     DateTime  @default(now())
  bets          Bet[]
}

model Bet {
  id          String   @id @default(cuid())
  drawId      String
  draw        Draw     @relation(fields: [drawId], references: [id], onDelete: Cascade)
  number      String
  amount      Float
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([drawId, number])
}

model NumberLimit {
  id       String  @id @default(cuid())
  houseId  String
  house    House   @relation(fields: [houseId], references: [id], onDelete: Cascade)
  number   String
  maxRisk  Int?
  maxSets  Int?

  @@unique([houseId, number])
}
